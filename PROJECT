domain: oracle.com
layout:
- go.kubebuilder.io/v4
multigroup: true
plugins:
  manifests.sdk.operatorframework.io/v2: {}
  scorecard.sdk.operatorframework.io/v2: {}
projectName: oci-service-operator
repo: github.com/oracle/oci-service-operator
resources:
- api:
    crdVersion: v1
    namespaced: true
  controller: true
  domain: oracle.com
  group: database
  kind: AutonomousDatabases
  path: github.com/oracle/oci-service-operator/api/database/v1beta1
  version: v1beta1
  webhooks:
    webhookVersion: v1
- api:
    crdVersion: v1
    namespaced: true
  controller: true
  domain: oracle.com
  group: streaming
  kind: Stream
  path: github.com/oracle/oci-service-operator/api/streaming/v1beta1
  version: v1beta1
- api:
    crdVersion: v1
    namespaced: true
  controller: true
  domain: oracle.com
  group: mysql
  kind: MySqlDbSystem
  path: github.com/oracle/oci-service-operator/api/mysql/v1beta1
  version: v1beta1
version: "3"
