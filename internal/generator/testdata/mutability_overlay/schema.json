          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "terraformFieldPath": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "required": [
        "astFieldPath",
        "terraformFieldPath",
        "canonicalJoinKey",
        "pathShape",
        "ast",
        "docs",
        "merge",
