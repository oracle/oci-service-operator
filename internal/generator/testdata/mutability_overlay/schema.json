  "$id": "https://oracle.com/oci-service-operator/schemas/generator/mutability-overlay-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contractVersion": {
