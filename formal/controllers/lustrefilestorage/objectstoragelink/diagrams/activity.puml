partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired ObjectStorageLink spec, tracked\nstatus, and delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via\nGetObjectStorageLink;
else (no)
:Resolve an existing OCI resource through\nListObjectStorageLinks using filters\navailability_domain, compartment_id,\ndisplay_name, id (+2 more);
:Create the OCI resource via\nCreateObjectStorageLink when no reusable match\nis found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteObjectStorageLink with\nrequired via GetObjectStorageLink or\nListObjectStorageLinks to DELETED confirmation;
:Confirm deletion via GetObjectStorageLink or\nListObjectStorageLinks until OCI reaches\nDELETED;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in CREATING,\nDELETING;
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the imported\nfield surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields availability_domain, compartment_id,\nfile_system_path, lustre_file_system_id (+1\nmore);
stop
endif
if ("Supported mutable drift detected?") then (yes)
:Apply UpdateObjectStorageLink only for mutable\nfields defined_tags, display_name,\nfreeform_tags, is_overwrite;
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource;\nupdate=tfresource.UpdateResource;\ndelete=tfresource.DeleteResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=objectstoragelink action=DELETED when\nthe matching field-driven path executes;
:Return success for the ACTIVE success state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, terminating;
}
endif
stop
