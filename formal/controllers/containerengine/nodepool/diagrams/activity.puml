@startuml
skinparam shadowing false
skinparam backgroundColor #fcfcfd
skinparam defaultFontName Helvetica
skinparam defaultFontSize 14
skinparam arrowColor #0f172a
skinparam noteBackgroundColor #fff7d6
skinparam noteBorderColor #b45309
skinparam noteFontColor #334155
skinparam roundcorner 16
title Activity - containerengine/NodePool
skinparam activity {
  backgroundColor #f8fafc
  borderColor #0f172a
  fontColor #0f172a
  diamondBackgroundColor #e2e8f0
  diamondBorderColor #1d4ed8
  diamondFontColor #0f172a
  startColor #1d4ed8
  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired NodePool spec, tracked status,\nand delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via GetNodePool;
else (no)
:Resolve an existing OCI resource through\nListNodePools using filters compartment_id,\ncluster_id, lifecycle_state, name;
:Create the OCI resource via CreateNodePool\nwhen no reusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteNodePool with required\nvia GetNodePool or ListNodePools to DELETED\nconfirmation;
:Confirm deletion via GetNodePool or\nListNodePools until OCI reaches DELETED;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in CREATING,\nUPDATING, DELETING;
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE, INACTIVE, NEEDS_ATTENTION;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the imported\nfield surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields cluster_id, compartment_id,\nnode_image_name and conflicts\nnode_config_details -> quantity_per_subnet,\nsubnet_ids, quantity_per_subnet ->\nnode_config_details, subnet_ids ->\nnode_config_details;
stop
endif
:Enforce conflictsWith rules\nnode_config_details -> quantity_per_subnet,\nsubnet_ids, quantity_per_subnet ->\nnode_config_details, subnet_ids ->\nnode_config_details before any OCI mutation;
if ("Supported mutable drift detected?") then (yes)
:Apply UpdateNodePool only for mutable fields\ndefined_tags, freeform_tags,\ninitial_node_labels, kubernetes_version (+11\nmore);
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource;\nupdate=tfresource.UpdateResource;\ndelete=tfresource.DeleteResource when the\nmatching field-driven path executes;
:Return success for the ACTIVE, INACTIVE,\nNEEDS_ATTENTION success state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
}
endif
stop
note right
shared diagram:
shared/diagrams/shared-reconcile-activity.svg
Start from the shared reconcile activity and
specialize provider-backed CRUD, wait, and
status-projection details here.
Controller-local activity diagrams add
list-lookup hints, secret policies, delete
handling, and open formal gaps.
archetype batch: Generated service-manager
controllers specialize the shared reconcile path
with formal runtime ownership.
service: containerengine
slug: nodepool
kind: NodePool
archetype: generated-service-manager
status/finalizer: required /
retain-until-confirmed-delete
requeue: provisioning, updating, terminating
provider states: create CREATING; update
UPDATING; delete DELETING
supported drift: defined_tags, freeform_tags,
initial_node_labels, kubernetes_version (+11
more)
reject before mutate: force-new fields
cluster_id, compartment_id, node_image_name and
conflicts node_config_details ->
quantity_per_subnet, subnet_ids,
quantity_per_subnet -> node_config_details,
subnet_ids -> node_config_details
create-only fields: none
list lookup: oci_containerengine_node_pools
filters compartment_id, cluster_id,
lifecycle_state, name
conflicts: node_config_details ->
quantity_per_subnet, subnet_ids,
quantity_per_subnet -> node_config_details,
subnet_ids -> node_config_details
open gaps: none
Ready state maps to OCI ACTIVE, INACTIVE, or
NEEDS_ATTENTION.
Requeue continues while OCI reports CREATING,
UPDATING, or DELETING.
Bind-before-create reuses only exact compartment
and cluster matches that remain in ACTIVE,
CREATING, UPDATING, INACTIVE, or
NEEDS_ATTENTION.
Delete completes after GetNodePool or
ListNodePools returns DELETED or no longer finds
the resource.
end note
@enduml
