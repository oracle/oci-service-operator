@startuml
skinparam shadowing false
skinparam backgroundColor #fcfcfd
skinparam defaultFontName Helvetica
skinparam defaultFontSize 14
skinparam arrowColor #0f172a
skinparam noteBackgroundColor #fff7d6
skinparam noteBorderColor #b45309
skinparam noteFontColor #334155
skinparam roundcorner 16
title Activity - databasemigration/Assessment
skinparam activity {
  backgroundColor #f8fafc
  borderColor #0f172a
  fontColor #0f172a
  diamondBackgroundColor #e2e8f0
  diamondBorderColor #1d4ed8
  diamondFontColor #0f172a
  startColor #1d4ed8
  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired Assessment spec, tracked status,\nand delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via GetAssessment;
else (no)
:Resolve an existing OCI resource through\nListAssessments using filters compartment_id,\ndisplay_name, lifecycle_details,\nlifecycle_state;
:Create the OCI resource via CreateAssessment\nwhen no reusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteAssessment with\nrequired via GetAssessment or ListAssessments\nto DELETED confirmation;
:Confirm deletion via GetAssessment or\nListAssessments until OCI reaches DELETED;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in CREATING,\nIN_PROGRESS, UPDATING, DELETING;
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE, SUCCEEDED;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the imported\nfield surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields bulk_include_exclude_data,\ncompartment_id, database_combination,\nexclude_objects (+1 more);
stop
endif
if ("Supported mutable drift detected?") then (yes)
:Apply UpdateAssessment only for mutable fields\nacceptable_downtime, creation_type,\ndatabase_data_size, ddl_expectation (+7 more);
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=assessment action=CREATED;\nupdate=tfresource.UpdateResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=assessment action=UPDATED;\ndelete=tfresource.DeleteResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=assessment action=DELETED when the\nmatching field-driven path executes;
:Return success for the ACTIVE, SUCCEEDED\nsuccess state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
}
endif
stop
note right
shared diagram:
shared/diagrams/shared-reconcile-activity.svg
Start from the shared reconcile activity and
specialize provider-backed CRUD, wait, and
status-projection details here.
Controller-local activity diagrams add
list-lookup hints, secret policies, delete
handling, and open formal gaps.
archetype batch: Generated service-manager
controllers specialize the shared reconcile path
with formal runtime ownership.
service: databasemigration
slug: assessment
kind: Assessment
archetype: generated-service-manager
status/finalizer: required /
retain-until-confirmed-delete
requeue: provisioning, updating, terminating
provider states: create CREATING, IN_PROGRESS;
update UPDATING, IN_PROGRESS; delete DELETING
supported drift: acceptable_downtime,
creation_type, database_data_size,
ddl_expectation (+7 more)
reject before mutate: force-new fields
bulk_include_exclude_data, compartment_id,
database_combination, exclude_objects (+1 more)
create-only fields: none
list lookup: oci_database_migration_assessments
filters compartment_id, display_name,
lifecycle_details, lifecycle_state
conflicts: none
open gaps: none
Scaffold metadata only; replace with
controller-specific runtime states before
promotion.
end note
@enduml
