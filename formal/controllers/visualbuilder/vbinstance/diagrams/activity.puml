partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired VbInstance spec, tracked status,\nand delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via GetVbInstance;
else (no)
:Resolve an existing OCI resource through\nListVbInstances using filters compartmentId,\ndisplayName;
:Create the OCI resource via CreateVbInstance\nwhen no reusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteVbInstance with\nrequired via GetVbInstance or ListVbInstances\nto DELETED confirmation;
:Confirm deletion via GetVbInstance or\nListVbInstances until OCI reaches DELETED;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in CREATING,\nUPDATING, DELETING;
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE, INACTIVE;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the\nrepo-authored mutation surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields compartmentId, consumptionModel,\nnetworkEndpointDetails.privateEndpointIp;
stop
endif
if ("Supported mutable drift detected?") then (yes)
:Apply UpdateVbInstance only for mutable fields\nalternateCustomEndpoints.certificateSecretId,\nalternateCustomEndpoints.hostname,\ncustomEndpoint.certificateSecretId,\ncustomEndpoint.hostname (+11 more);
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=vbinstance action=CREATED;\nupdate=tfresource.UpdateResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=vbinstance action=UPDATED;\ndelete=tfresource.DeleteResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=vbinstance action=DELETED when the\nmatching field-driven path executes;
:Apply explicit follow-up semantics\ncreate=GetWorkRequest -> GetVbInstance;\nupdate=GetWorkRequest -> GetVbInstance;\ndelete=GetWorkRequest ->\nGetVbInstance/ListVbInstances confirm-delete;
:Return success for the ACTIVE, INACTIVE\nsuccess state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
}
endif
stop
