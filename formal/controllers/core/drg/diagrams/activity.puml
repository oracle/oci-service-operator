@startuml
skinparam shadowing false
skinparam backgroundColor #fcfcfd
skinparam defaultFontName Helvetica
skinparam defaultFontSize 14
skinparam arrowColor #0f172a
skinparam noteBackgroundColor #fff7d6
skinparam noteBorderColor #b45309
skinparam noteFontColor #334155
skinparam roundcorner 16
title Activity - core/Drg
skinparam activity {
  backgroundColor #f8fafc
  borderColor #0f172a
  fontColor #0f172a
  diamondBackgroundColor #e2e8f0
  diamondBorderColor #1d4ed8
  diamondFontColor #0f172a
  startColor #1d4ed8
  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired Drg spec, tracked status, and\ndelete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via GetDrg;
else (no)
:Resolve an existing OCI resource through\nListDrgs using filters compartmentId,\ndisplayName;
:Create the OCI resource via CreateDrg when no\nreusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteDrg with required via\nGetDrg or ListDrgs to NOT_FOUND confirmation;
:Confirm deletion via GetDrg or ListDrgs until\nOCI reaches NOT_FOUND;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in\nPROVISIONING, UPDATING, TERMINATING,\nTERMINATED;
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches AVAILABLE;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the\nrepo-authored mutation surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields compartmentId;
stop
endif
if ("Supported mutable drift detected?") then (yes)
:Apply UpdateDrg only for mutable fields\ndefaultDrgRouteTables, definedTags,\ndisplayName, freeformTags;
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=template action=CREATED;\nupdate=tfresource.UpdateResource;\ndelete=tfresource.DeleteResource when the\nmatching field-driven path executes;
:Apply explicit follow-up semantics\ndelete=confirm-delete;
:Return success for the AVAILABLE success state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
}
endif
stop
note right
shared diagram:
shared/diagrams/shared-reconcile-activity.svg
Start from the shared reconcile activity and
specialize provider-backed CRUD, wait, and
status-projection details here.
Controller-local activity diagrams add
list-lookup hints, secret policies, delete
handling, and open formal gaps.
archetype batch: Generated service-manager
controllers specialize the shared reconcile path
with formal runtime ownership.
service: core
slug: drg
kind: Drg
archetype: generated-service-manager
status/finalizer: required /
retain-until-confirmed-delete
requeue: provisioning, updating, terminating
provider states: create PROVISIONING; update
UPDATING; delete TERMINATING, TERMINATED
follow-up: delete=confirm-delete
supported drift: defaultDrgRouteTables,
definedTags, displayName, freeformTags
reject before mutate: force-new fields
compartmentId
create-only fields: none
list lookup: oci_core_drgs filters
compartmentId, displayName; tracked OCI ID via
GetDrg wins; otherwise exact compartmentId plus
displayName unique match in AVAILABLE,
PROVISIONING, or UPDATING; blank displayName
skips reuse and duplicate matches fail
conflicts: none
open gaps: none
Ready state maps to OCI AVAILABLE.
CreateDrgDetails does not expose
defaultDrgRouteTables, so requested
attachment-type defaults reconcile through
UpdateDrg after the DRG exists.
Delete completes only after GetDrg returns not
found; TERMINATING and TERMINATED are accepted
observed pre-delete states.
The create-fallback wrapper only recovers
first-create post-read failures when status
already carries a created DRG OCID and a
provisioning-like or AVAILABLE lifecycle state.
end note
@enduml
