@startuml
skinparam shadowing false
skinparam backgroundColor #fcfcfd
skinparam defaultFontName Helvetica
skinparam defaultFontSize 14
skinparam arrowColor #0f172a
skinparam noteBackgroundColor #fff7d6
skinparam noteBorderColor #b45309
skinparam noteFontColor #334155
skinparam roundcorner 16
title Activity - core/Instance
skinparam activity {
  backgroundColor #f8fafc
  borderColor #0f172a
  fontColor #0f172a
  diamondBackgroundColor #e2e8f0
  diamondBorderColor #1d4ed8
  diamondFontColor #0f172a
  startColor #1d4ed8
  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired Instance spec, tracked status,\nand delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via GetInstance;
else (no)
:Resolve an existing OCI resource through\nListInstances using filters\navailability_domain, compartment_id,\ndisplay_name, lifecycle_state;
:Create the OCI resource via LaunchInstance\nwhen no reusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses TerminateInstance with\nrequired via GetInstance or ListInstances to\nTERMINATED, NOT_FOUND confirmation;
:Confirm deletion via GetInstance or\nListInstances until OCI reaches TERMINATED,\nNOT_FOUND;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in\nPROVISIONING, STARTING, MOVING, STOPPING (+1\nmore);
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches RUNNING, STOPPED;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the imported\nfield surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields availability_domain, compartment_id,\nshape, shape_config (+2 more);
stop
endif
if ("Supported mutable drift detected?") then (yes)
:Apply UpdateInstance only for mutable fields\ndefined_tags, display_name, freeform_tags;
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource;\nupdate=tfresource.UpdateResource;\ndelete=tfresource.DeleteResource when the\nmatching field-driven path executes;
:Return success for the RUNNING, STOPPED\nsuccess state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
}
endif
stop
note right
shared diagram:
shared/diagrams/shared-reconcile-activity.svg
Start from the shared reconcile activity and
specialize provider-backed CRUD, wait, and
status-projection details here.
Controller-local activity diagrams add
list-lookup hints, secret policies, delete
handling, and open formal gaps.
archetype batch: Generated service-manager
controllers specialize the shared reconcile path
with formal runtime ownership.
service: core
slug: instance
kind: Instance
archetype: generated-service-manager
status/finalizer: required /
retain-until-confirmed-delete
requeue: provisioning, updating, terminating
provider states: create PROVISIONING, STARTING;
update MOVING, STOPPING; delete TERMINATING
supported drift: defined_tags, display_name,
freeform_tags
reject before mutate: force-new fields
availability_domain, compartment_id, shape,
shape_config (+2 more)
create-only fields: none
list lookup: oci_core_instances filters
availability_domain, compartment_id,
display_name, lifecycle_state
conflicts: none
open gaps: none
Create uses LaunchInstance and projects the
returned OCI Instance into status before later
reconciles observe with GetInstance or a
narrowed ListInstances lookup.
Ready state covers OCI RUNNING and STOPPED.
Requeue continues while OCI reports
PROVISIONING, STARTING, MOVING, STOPPING, or
TERMINATING.
Delete remains finalizer-backed until OCI
readback reports TERMINATED or stops finding the
tracked instance.
end note
@enduml
