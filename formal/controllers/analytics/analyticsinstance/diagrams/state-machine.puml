service: analytics
slug: analyticsinstance
kind: AnalyticsInstance
archetype: generated-service-manager
status/finalizer: required /
retain-until-confirmed-delete
requeue: provisioning, updating, terminating
provider states: create CREATING; update none;
delete DELETING
supported drift: capacity.capacity_value,
compartment_id, defined_tags, description (+14
more)
reject before mutate: force-new fields
admin_user, capacity.capacity_type, domain_id,
feature_bundle (+3 more)
create-only fields: none
