  diamondBackgroundColor #e2e8f0
  diamondBorderColor #1d4ed8
  diamondFontColor #0f172a
  startColor #1d4ed8
  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired Domain spec, tracked status, and\ndelete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via GetDomain;
else (no)
:Resolve an existing OCI resource through\nListDomains using filters compartmentId,\ndomainName, lifecycleState, status;
:Create the OCI resource via CreateDomain when\nno reusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteDomain with required\nvia GetDomain or ListDomains to DELETED,\nNOT_FOUND confirmation;
:Confirm deletion via GetDomain or ListDomains\nuntil OCI reaches DELETED, NOT_FOUND;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the\nrepo-authored mutation surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields compartmentId, domainName,\nisGovernanceEnabled, subscriptionEmail;
stop
endif
if ("Supported mutable drift detected?") then (yes)
:Apply UpdateDomain only for mutable fields\ndefinedTags, freeformTags;
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=domain action=REGISTER_DOMAIN;\nupdate=tfresource.UpdateResource;\ndelete=tfresource.DeleteResource when the\nmatching field-driven path executes;
:Apply explicit follow-up semantics\ncreate=GetWorkRequest -> GetDomain;\nupdate=none; delete=GetDomain/ListDomains\nconfirm-delete;
:Return success for the ACTIVE success state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, terminating;
}
endif
stop
