description, displayName (+2 more)
reject before mutate: force-new fields
dashboardGroupId, schemaVersion, systemTags
create-only fields: none
list lookup: oci_dashboard_service_dashboards
filters dashboardGroupId, displayName; exact
dashboardGroupId plus displayName unique match
