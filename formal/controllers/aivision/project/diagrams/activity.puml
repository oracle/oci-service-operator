@startuml
skinparam shadowing false
skinparam backgroundColor #fcfcfd
skinparam defaultFontName Helvetica
skinparam defaultFontSize 14
skinparam arrowColor #0f172a
skinparam noteBackgroundColor #fff7d6
skinparam noteBorderColor #b45309
skinparam noteFontColor #334155
skinparam roundcorner 16
title Activity - aivision/Project
skinparam activity {
  backgroundColor #f8fafc
  borderColor #0f172a
  fontColor #0f172a
  diamondBackgroundColor #e2e8f0
  diamondBorderColor #1d4ed8
  diamondFontColor #0f172a
  startColor #1d4ed8
  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired Project spec, tracked status, and\ndelete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via GetProject;
else (no)
:Resolve an existing OCI resource through\nListProjects using filters compartment_id,\ndisplay_name, id, state;
:Create the OCI resource via CreateProject when\nno reusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteProject with required\nvia GetProject or ListProjects to DELETED\nconfirmation;
:Confirm deletion via GetProject or\nListProjects until OCI reaches DELETED;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in CREATING,\nUPDATING, DELETING;
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the imported\nfield surface;
if ("Supported mutable drift detected?") then (yes)
:Apply ChangeProjectCompartment, UpdateProject\nonly for mutable fields compartment_id,\ndefined_tags, description, display_name (+1\nmore);
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource;\nupdate=tfresource.UpdateResource,\ntfresource.WaitForUpdatedState;\ndelete=tfresource.DeleteResource when the\nmatching field-driven path executes;
:Return success for the ACTIVE success state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
}
endif
stop
note right
shared diagram:
shared/diagrams/shared-reconcile-activity.svg
Start from the shared reconcile activity and
specialize provider-backed CRUD, wait, and
status-projection details here.
Controller-local activity diagrams add
list-lookup hints, secret policies, delete
handling, and open formal gaps.
archetype batch: Generated service-manager
controllers specialize the shared reconcile path
with formal runtime ownership.
service: aivision
slug: project
kind: Project
archetype: generated-service-manager
status/finalizer: required /
retain-until-confirmed-delete
requeue: provisioning, updating, terminating
provider states: create CREATING; update
UPDATING; delete DELETING
supported drift: compartment_id, defined_tags,
description, display_name (+1 more)
reject before mutate: none
create-only fields: none
list lookup: oci_ai_vision_projects filters
compartment_id, display_name, id, state
conflicts: none
open gaps: none
Generated runtime uses read-after-write
follow-up for create and update plus
confirm-delete for delete; `CREATING` maps to
provisioning, `ACTIVE` to success, `UPDATING` to
updating, and `DELETING` keeps reconcile in the
terminating bucket until `DELETED` or NotFound.
Pre-create lookup queries `ListProjects` with
`compartmentId`, `displayName`, and an optional
tracked `id`; delete fallback can re-resolve the
tracked project through `ListProjects` when
`GetProject` returns NotFound.
Only `displayName`, `description`,
`freeformTags`, and `definedTags` reconcile in
place. `compartmentId` remains replacement-only
drift and the runtime has no secret side
effects.
end note
@enduml
