@startuml
skinparam shadowing false
skinparam backgroundColor #fcfcfd
skinparam defaultFontName Helvetica
skinparam defaultFontSize 14
skinparam arrowColor #0f172a
skinparam noteBackgroundColor #fff7d6
skinparam noteBorderColor #b45309
skinparam noteFontColor #334155
skinparam roundcorner 16
title Activity - database/AutonomousDatabases
skinparam activity {
  backgroundColor #f8fafc
  borderColor #0f172a
  fontColor #0f172a
  diamondBackgroundColor #e2e8f0
  diamondBorderColor #1d4ed8
  diamondFontColor #0f172a
  startColor #1d4ed8
  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired AutonomousDatabases spec, tracked\nstatus, and delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via\nGetAutonomousDatabase;
else (no)
:Resolve an existing OCI resource through\nListAutonomousDatabases using filters\nautonomous_container_database_id,\ncompartment_id, db_version, db_workload (+9\nmore);
:Create the OCI resource via\nCreateAutonomousDatabase,\nUpdateAutonomousDatabase when no reusable\nmatch is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete stays repo-authored not-supported\ndespite provider op DeleteAutonomousDatabase;
:Delete owned Secret side effects only after\nOCI delete confirmation;
:Allow best-effort completion without finalizer\nretention;
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in\nPROVISIONING, STARTING,\nMAINTENANCE_IN_PROGRESS, RESTARTING (+6 more);
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches AVAILABLE, STANDBY;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the imported\nfield surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields autonomous_container_database_id,\nautonomous_database_backup_id,\nautonomous_database_id, character_set (+12\nmore) and conflicts is_shrink_only ->\nshrink_adb_trigger;
stop
endif
:Enforce conflictsWith rules is_shrink_only ->\nshrink_adb_trigger before any OCI mutation;
if ("Supported mutable drift detected?") then (yes)
:Apply ChangeAutonomousDatabaseCompartment,\nChangeAutonomousDatabaseSubscription,\nConfigureAutonomousDatabaseVaultKey (+7 more)\nonly for mutable fields admin_password,\nare_primary_whitelisted_ips_used,\nauto_refresh_frequency_in_seconds,\nauto_refresh_point_lag_in_seconds (+107 more);
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.WaitForWorkRequestWithErrorHandling\nentity=database action=CREATED,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=database action=UPDATED;\nupdate=tfresource.WaitForWorkRequestWithErrorHandling\nentity=database action=UPDATED;\ndelete=tfresource.DeleteResource when the\nmatching field-driven path executes;
:Apply repo-authored secret policy ready-only\nwrites after ACTIVE plus secret-input reads;
if ("Secret sync succeeds?") then (yes)
:Return success for the AVAILABLE, STANDBY\nsuccess state;
else (no)
:Block successful completion until Secret sync\nsucceeds;
endif
:Project manual status and finalizer policy\nnone;
:Requeue on provisioning, updating;
:Keep promotion blocked on bind-versus-create,\ndelete-confirmation, legacy-adapter,\nlist-lookup, manual-webhook (+4 more);
}
endif
stop
note right
shared diagram:
shared/diagrams/shared-reconcile-activity.svg
