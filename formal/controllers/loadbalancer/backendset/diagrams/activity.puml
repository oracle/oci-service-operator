}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired BackendSet spec, tracked status,\nand delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via GetBackendSet;
else (no)
:Resolve an existing OCI resource through\nListBackendSets using filters name;
:Create the OCI resource via CreateBackendSet\nwhen no reusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteBackendSet with\nrequired via GetBackendSet or ListBackendSets\nto DELETED confirmation;
:Confirm deletion via GetBackendSet or\nListBackendSets until OCI reaches DELETED;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the\nrepo-authored mutation surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields load_balancer_id, name and conflicts\nlb_cookie_session_persistence_configuration ->\nsession_persistence_configuration,\nsession_persistence_configuration ->\nlb_cookie_session_persistence_configuration;
stop
endif
:Enforce conflictsWith rules\nlb_cookie_session_persistence_configuration ->\nsession_persistence_configuration,\nsession_persistence_configuration ->\nlb_cookie_session_persistence_configuration\nbefore any OCI mutation;
if ("Supported mutable drift detected?") then (yes)
:Apply UpdateBackendSet only for mutable fields\nbackends, health_checker,\nlb_cookie_session_persistence_configuration,\npolicy (+2 more);
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource;\nupdate=tfresource.UpdateResource;\ndelete=tfresource.DeleteResource when the\nmatching field-driven path executes;
:Return success for the ACTIVE success state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
}
endif
stop
