  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired PrivateServiceAccess spec,\ntracked status, and delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via\nGetPrivateServiceAccess;
else (no)
:Resolve an existing OCI resource through\nListPrivateServiceAccesses using filters\ncompartmentId, displayName, serviceId, id;
:Create the OCI resource via\nCreatePrivateServiceAccess when no reusable\nmatch is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeletePrivateServiceAccess\nwith required via GetPrivateServiceAccess or\nListPrivateServiceAccesses to DELETED\nconfirmation;
:Confirm deletion via GetPrivateServiceAccess\nor ListPrivateServiceAccesses until OCI\nreaches DELETED;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in CREATING,\nUPDATING, DELETING;
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the\nrepo-authored mutation surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields compartmentId, ipv4Ip, serviceId,\nsubnetId;
stop
endif
if ("Supported mutable drift detected?") then (yes)
:Apply ChangePrivateServiceAccessCompartment,\nUpdatePrivateServiceAccess only for mutable\nfields definedTags, description, displayName,\nfreeformTags (+2 more);
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=privateserviceaccess action=CREATED;\nupdate=tfresource.UpdateResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=privateserviceaccess action=UPDATED;\ndelete=tfresource.DeleteResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=privateserviceaccess action=DELETED\nwhen the matching field-driven path executes;
:Apply explicit follow-up semantics\ncreate=GetPsaWorkRequest ->\nGetPrivateServiceAccess;\nupdate=GetPsaWorkRequest ->\nGetPrivateServiceAccess;\ndelete=GetPsaWorkRequest ->\nGetPrivateServiceAccess/ListPrivateServiceAccesses\nconfirm-delete;
:Return success for the ACTIVE success state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
}
endif
stop
