@startuml
skinparam shadowing false
skinparam backgroundColor #fcfcfd
skinparam defaultFontName Helvetica
skinparam defaultFontSize 14
skinparam arrowColor #0f172a
skinparam noteBackgroundColor #fff7d6
skinparam noteBorderColor #b45309
skinparam noteFontColor #334155
skinparam roundcorner 16
title Activity - psql/DbSystem
skinparam activity {
  backgroundColor #f8fafc
  borderColor #0f172a
  fontColor #0f172a
  diamondBackgroundColor #e2e8f0
  diamondBorderColor #1d4ed8
  diamondFontColor #0f172a
  startColor #1d4ed8
  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired DbSystem spec, tracked status,\nand delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via GetDbSystem;
else (no)
:Resolve an existing OCI resource through\nListDbSystems using filters compartment_id,\ndisplay_name, id, state;
:Create the OCI resource via CreateDbSystem\nwhen no reusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteDbSystem with required\nvia GetDbSystem or ListDbSystems to DELETED\nconfirmation;
:Confirm deletion via GetDbSystem or\nListDbSystems until OCI reaches DELETED;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in CREATING,\nDELETING;
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE, NEEDS_ATTENTION;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the imported\nfield surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields credentials, credentials.username,\ndb_version, instances_details (+13 more);
stop
endif
if ("Supported mutable drift detected?") then (yes)
:Apply ChangeDbSystemCompartment,\nPatchDbSystem, ResetMasterUserPassword (+1\nmore) only for mutable fields apply_config,\ncompartment_id, config_id,\ncredentials.password_details.password (+29\nmore);
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource;\nupdate=tfresource.UpdateResource,\ntfresource.WaitForUpdatedState;\ndelete=tfresource.DeleteResource when the\nmatching field-driven path executes;
:Return success for the ACTIVE, NEEDS_ATTENTION\nsuccess state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
:Keep promotion blocked on bind-versus-create,\nlist-lookup, mutation-policy,\nwaiter-work-request;
}
endif
stop
note right
shared diagram:
shared/diagrams/shared-reconcile-activity.svg
Start from the shared reconcile activity and
specialize provider-backed CRUD, wait, and
status-projection details here.
Controller-local activity diagrams add
list-lookup hints, secret policies, delete
handling, and open formal gaps.
archetype batch: Generated service-manager
controllers specialize the shared reconcile path
with formal runtime ownership.
service: psql
slug: dbsystem
kind: DbSystem
archetype: generated-service-manager
status/finalizer: required /
retain-until-confirmed-delete
requeue: provisioning, updating, terminating
provider states: create CREATING; update none;
delete DELETING
supported drift: apply_config, compartment_id,
config_id, credentials.password_details.password
(+29 more)
reject before mutate: force-new fields
credentials, credentials.username, db_version,
instances_details (+13 more)
list lookup: oci_psql_db_systems filters
compartment_id, display_name, id, state
conflicts: none
open gaps: bind-versus-create, list-lookup,
mutation-policy, waiter-work-request
Scaffold metadata only; replace with
controller-specific runtime states before
promotion.
end note
@enduml
