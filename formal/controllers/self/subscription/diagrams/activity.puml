@startuml
skinparam shadowing false
skinparam backgroundColor #fcfcfd
skinparam defaultFontName Helvetica
skinparam defaultFontSize 14
skinparam arrowColor #0f172a
skinparam noteBackgroundColor #fff7d6
skinparam noteBorderColor #b45309
skinparam noteFontColor #334155
skinparam roundcorner 16
title Activity - self/Subscription
skinparam activity {
  backgroundColor #f8fafc
  borderColor #0f172a
  fontColor #0f172a
  diamondBackgroundColor #e2e8f0
  diamondBorderColor #1d4ed8
  diamondFontColor #0f172a
  startColor #1d4ed8
  endColor #0f172a
  barColor #1d4ed8
}
start
partition "Observe and Bind" {
:Start from shared flow\nshared/diagrams/shared-reconcile-activity.svg;
:Read desired Subscription spec, tracked\nstatus, and delete intent;
if ("Tracked or explicit OCI identity present?") then (yes)
:Get the current OCI resource via\nGetSubscription;
else (no)
:Resolve an existing OCI resource through\nListSubscriptions using filters\ncompartment_id, display_name, id,\nlifecycle_details;
:Create the OCI resource via CreateSubscription\nwhen no reusable match is found;
:Persist the resolved or created OCI identity\ninto status;
endif
}
if ("Delete requested?") then (yes)
partition "Delete" {
:Delete path uses DeleteSubscription with\nrequired via GetSubscription or\nListSubscriptions to DELETED, NOT_FOUND\nconfirmation;
:Confirm deletion via GetSubscription or\nListSubscriptions until OCI reaches DELETED,\nNOT_FOUND;
if ("Delete cleanup and finalizer release succeed?") then (yes)
:Remove the finalizer after delete completion;
else (no)
:Stay blocked until cleanup or finalizer\nrelease succeeds;
endif
}
stop
else (no)
partition "Lifecycle Classification" {
if ("OCI state in retryable set?") then (yes)
:Request requeue while OCI remains in CREATED,\nPENDING_ACTIVATION, PROVISIONING_STARTED,\nPROVISIONING_COMPLETED (+2 more);
stop
endif
if ("OCI state is outside success targets?") then (yes)
:Return an unsuccessful reconcile result until\nOCI reaches ACTIVE;
stop
endif
}
partition "Ready and Drift Handling" {
:Compare live OCI state against the imported\nfield surface;
if ("Force-new or conflicting drift detected?") then (yes)
:Reject drift before OCI mutation for force-new\nfields compartment_id, tenant_id, seller_id,\nproduct_id (+5 more);
stop
endif
if ("Supported mutable drift detected?") then (yes)
:Apply UpdateSubscription only for mutable\nfields display_name, freeform_tags,\ndefined_tags;
else (no)
:Skip the no-op mutation path;
endif
:Run provider helper hooks\ncreate=tfresource.CreateResource,\ntfresource.WaitForWorkRequestWithErrorHandling\nentity=template action=CREATED;\nupdate=tfresource.UpdateResource;\ndelete=tfresource.DeleteResource when the\nmatching field-driven path executes;
:Return success for the ACTIVE success state;
:Project required status and finalizer policy\nretain-until-confirmed-delete;
:Requeue on provisioning, updating, terminating;
:Keep promotion blocked on drift-guard;
}
endif
stop
note right
shared diagram:
shared/diagrams/shared-reconcile-activity.svg
Start from the shared reconcile activity and
specialize provider-backed CRUD, wait, and
status-projection details here.
Controller-local activity diagrams add
list-lookup hints, secret policies, delete
handling, and open formal gaps.
archetype batch: Generated service-manager
controllers specialize the shared reconcile path
with formal runtime ownership.
service: self
slug: subscription
kind: Subscription
archetype: generated-service-manager
status/finalizer: required /
retain-until-confirmed-delete
requeue: provisioning, updating, terminating
provider states: create CREATED,
PENDING_ACTIVATION, PROVISIONING_STARTED,
PROVISIONING_COMPLETED; update UPDATING; delete
DELETING
supported drift: display_name, freeform_tags,
defined_tags
reject before mutate: force-new fields
compartment_id, tenant_id, seller_id, product_id
(+5 more)
create-only fields: none
list lookup: oci_self_subscriptions filters
compartment_id, display_name, id,
lifecycle_details
conflicts: none
open gaps: drift-guard
Create, update, and delete are
workrequest-backed and re-enter through
GetWorkRequest before rereading Subscription.
Provisioning, update, and delete confirmation
classification uses lifecycleDetails because
coarse lifecycleState is too coarse for SELF
subscriptions.
Keep the SELF subscription rollout distinct from
ons/Subscription in shared formal surfaces.
end note
@enduml
