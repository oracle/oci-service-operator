        "requestType": "nosql.GetTableRequest",
        "responseType": "nosql.GetTableResponse"
      }
    ],
    "list": [
      {
        "operation": "ListTables",
        "requestType": "nosql.ListTablesRequest",
        "responseType": "nosql.ListTablesResponse"
      }
    ],
    "update": [
