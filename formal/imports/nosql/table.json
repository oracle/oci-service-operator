        "operation": "ChangeTableCompartment",
        "requestType": "nosql.ChangeTableCompartmentRequest",
        "responseType": "nosql.ChangeTableCompartmentResponse"
      },
      {
        "operation": "UpdateTable",
        "requestType": "nosql.UpdateTableRequest",
        "responseType": "nosql.UpdateTableResponse"
      }
    ],
    "delete": [
      {
        "operation": "DeleteTable",
        "requestType": "nosql.DeleteTableRequest",
        "responseType": "nosql.DeleteTableResponse"
      }
    ]
  },
  "lifecycle": {
