{
  "schemaVersion": 1,
  "surface": "provider-facts",
  "service": "containerengine",
  "slug": "cluster",
  "kind": "Cluster",
  "sourceRef": "terraform-provider-oci",
  "providerResource": "oci_containerengine_cluster",
  "operations": {
    "create": [
      {
        "operation": "CreateCluster",
        "requestType": "containerengine.CreateClusterRequest",
        "responseType": "containerengine.CreateClusterResponse"
      }
    ],
    "get": [
      {
        "operation": "GetCluster",
        "requestType": "containerengine.GetClusterRequest",
        "responseType": "containerengine.GetClusterResponse"
      }
    ],
    "list": [
      {
        "operation": "ListClusters",
        "requestType": "containerengine.ListClustersRequest",
        "responseType": "containerengine.ListClustersResponse"
      }
    ],
    "update": [
      {
        "operation": "UpdateCluster",
        "requestType": "containerengine.UpdateClusterRequest",
        "responseType": "containerengine.UpdateClusterResponse"
      }
    ],
    "delete": [
      {
        "operation": "DeleteCluster",
        "requestType": "containerengine.DeleteClusterRequest",
        "responseType": "containerengine.DeleteClusterResponse"
      }
    ]
  },
  "lifecycle": {
    "create": {
      "pending": [
        "CREATING",
        "UPDATING"
      ],
      "target": [
        "ACTIVE"
      ]
    },
    "update": {
      "pending": [
        "UPDATING"
      ],
      "target": [
        "ACTIVE"
      ]
    }
  },
  "mutation": {
    "mutable": [
      "defined_tags",
      "freeform_tags",
      "image_policy_config.is_policy_enabled",
      "image_policy_config.key_details.kms_key_id",
      "kubernetes_version",
      "name",
      "options.admission_controller_options.is_pod_security_policy_enabled",
      "options.persistent_volume_config.defined_tags",
      "options.persistent_volume_config.freeform_tags",
      "options.service_lb_config.defined_tags",
      "options.service_lb_config.freeform_tags",
      "type"
    ],
    "forceNew": [
      "cluster_pod_network_options.cni_type",
      "cluster_pod_network_options.json_data",
      "compartment_id",
      "endpoint_config.is_public_ip_enabled",
      "endpoint_config.nsg_ids",
      "endpoint_config.subnet_id",
      "kms_key_id",
      "options.add_ons.is_kubernetes_dashboard_enabled",
      "options.add_ons.is_tiller_enabled",
      "options.kubernetes_network_config.pods_cidr",
      "options.kubernetes_network_config.services_cidr",
      "options.service_lb_subnet_ids",
      "vcn_id"
    ],
    "conflictsWith": {}
  },
  "hooks": {
    "create": [
      {
        "helper": "tfresource.CreateResource"
      },
      {
        "helper": "tfresource.WaitForWorkRequestWithErrorHandling",
        "entityType": "cluster",
        "action": "CREATED"
      }
    ],
    "update": [
      {
        "helper": "tfresource.UpdateResource"
      },
      {
        "helper": "tfresource.WaitForWorkRequestWithErrorHandling",
        "entityType": "cluster",
        "action": "UPDATED"
      }
    ],
    "delete": [
      {
        "helper": "tfresource.DeleteResource"
      },
      {
        "helper": "tfresource.WaitForWorkRequestWithErrorHandling",
        "entityType": "cluster",
        "action": "DELETED"
      }
    ]
  },
  "deleteConfirmation": {
    "pending": [
      "DELETING"
    ],
    "target": [
      "DELETED"
    ]
  },
  "listLookup": {
    "datasource": "oci_containerengine_clusters",
    "collectionField": "clusters",
    "responseItemsField": "Items",
    "filterFields": [
      "compartment_id",
      "lifecycle_state",
      "name"
    ]
  },
  "boundary": {
    "providerFactsOnly": true,
    "repoAuthoredSpecPath": "controllers/containerengine/cluster/spec.cfg",
    "repoAuthoredLogicGapsPath": "controllers/containerengine/cluster/logic-gaps.md",
    "excludedSemantics": [
      "bind-versus-create",
      "secret-output"
    ]
  },
  "notes": [
    "Pinned OCI SDK contract: Cluster lifecycle exposes CREATING, ACTIVE, FAILED, DELETING, DELETED, and UPDATING. Repo-authored controller success is ACTIVE, requeue covers CREATING and UPDATING, FAILED is terminal without requeue, and delete confirmation follows DELETING to DELETED.",
    "Pinned OCI SDK contract: UpdateClusterDetails exposes name, kubernetes_version, options.admission_controller_options, options.persistent_volume_config, options.service_lb_config, defined_tags, freeform_tags, image_policy_config, and type as in-place update fields. Fields absent from UpdateClusterDetails remain create-only drift and must not open implicit replacement.",
    "CreateCluster, UpdateCluster, and DeleteCluster each return opc-work-request-id headers, so provider wait hooks are work-request-backed even though steady-state readiness is still classified from observed Cluster lifecycle states.",
    "ListClustersRequest filters by compartmentId, lifecycleState, and name and returns Items []ClusterSummary. Safe reusable matching is exact compartment_id plus name, restricted to reusable ACTIVE, CREATING, or UPDATING candidates; duplicate exact-name matches must fail instead of guessing."
  ]
}
