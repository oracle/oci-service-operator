{
  "schemaVersion": 1,
  "surface": "provider-facts",
  "service": "dataflow",
  "slug": "application",
  "kind": "Application",
  "sourceRef": "terraform-provider-oci",
  "providerResource": "oci_dataflow_application",
  "operations": {
    "create": [
      {
        "operation": "CreateApplication",
        "requestType": "dataflow.CreateApplicationRequest",
        "responseType": "dataflow.CreateApplicationResponse"
      }
    ],
    "get": [
      {
        "operation": "GetApplication",
        "requestType": "dataflow.GetApplicationRequest",
        "responseType": "dataflow.GetApplicationResponse"
      }
    ],
    "update": [
      {
        "operation": "UpdateApplication",
        "requestType": "dataflow.UpdateApplicationRequest",
        "responseType": "dataflow.UpdateApplicationResponse"
      }
    ],
    "delete": [
      {
        "operation": "DeleteApplication",
        "requestType": "dataflow.DeleteApplicationRequest",
        "responseType": "dataflow.DeleteApplicationResponse"
      }
    ]
  },
  "lifecycle": {
    "create": {
      "pending": [],
      "target": [
        "ACTIVE",
        "INACTIVE"
      ]
    },
    "update": {
      "pending": [],
      "target": [
        "ACTIVE",
        "INACTIVE"
      ]
    }
  },
  "mutation": {
    "mutable": [
      "application_log_config",
      "archive_uri",
      "arguments",
      "class_name",
      "configuration",
      "defined_tags",
      "description",
      "display_name",
      "driver_shape",
      "driver_shape_config",
      "execute",
      "executor_shape",
      "executor_shape_config",
      "file_uri",
      "freeform_tags",
      "idle_timeout_in_minutes",
      "language",
      "logs_bucket_uri",
      "max_duration_in_minutes",
      "metastore_id",
      "num_executors",
      "parameters",
      "pool_id",
      "private_endpoint_id",
      "spark_version",
      "warehouse_bucket_uri"
    ],
    "forceNew": [
      "compartment_id",
      "type"
    ],
    "conflictsWith": {}
  },
  "hooks": {
    "create": [
      {
        "helper": "tfresource.CreateResource"
      }
    ],
    "update": [
      {
        "helper": "tfresource.UpdateResource"
      }
    ],
    "delete": [
      {
        "helper": "tfresource.DeleteResource"
      }
    ]
  },
  "deleteConfirmation": {
    "pending": [
      "DELETED"
    ],
    "target": [
      "NOT_FOUND"
    ]
  },
  "boundary": {
    "providerFactsOnly": true,
    "repoAuthoredSpecPath": "controllers/dataflow/application/spec.cfg",
    "repoAuthoredLogicGapsPath": "controllers/dataflow/application/logic-gaps.md",
    "excludedSemantics": [
      "bind-versus-create",
      "delete-confirmation",
      "execute-precedence",
      "mutation-policy",
      "recreate-on-deleted",
      "status-projection"
    ]
  },
  "notes": [
    "Pinned OCI SDK contract imported from terraform-provider-oci for the published Application resource; the active generatedruntime-backed override uses CreateApplication/GetApplication/UpdateApplication/DeleteApplication and intentionally leaves ListApplications out of the live reconcile path.",
    "The active Application runtime preflights tracked OCIDs through GetApplication, clears recorded identity and recreates when OCI returns NotFound or lifecycle DELETED, and never adopts by display-name list lookup.",
    "Mutable drift is repo-authored: compartmentId and type stay create-only, execute suppresses subordinate className/fileUri/arguments/configuration/parameters drift, and the remaining Data Flow update surface is handled through custom generatedruntime request builders.",
    "Status projection replaces the published ApplicationStatus from the latest OCI payload so omitted optional fields clear, while delete confirmation keeps the finalizer until GetApplication returns not found even if OCI briefly echoes lifecycle DELETED."
  ]
}
