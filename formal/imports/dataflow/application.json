{
  "schemaVersion": 1,
  "surface": "provider-facts",
  "service": "dataflow",
  "slug": "application",
  "kind": "Application",
  "sourceRef": "terraform-provider-oci",
  "providerResource": "oci_dataflow_application",
  "operations": {
    "create": [
      {
        "operation": "CreateApplication",
        "requestType": "dataflow.CreateApplicationRequest",
        "responseType": "dataflow.CreateApplicationResponse"
      }
    ],
    "get": [
      {
        "operation": "GetApplication",
        "requestType": "dataflow.GetApplicationRequest",
        "responseType": "dataflow.GetApplicationResponse"
      }
    ],
    "list": [
      {
        "operation": "ListApplications",
        "requestType": "dataflow.ListApplicationsRequest",
        "responseType": "dataflow.ListApplicationsResponse"
      }
    ],
    "update": [
      {
        "operation": "UpdateApplication",
        "requestType": "dataflow.UpdateApplicationRequest",
        "responseType": "dataflow.UpdateApplicationResponse"
      }
    ],
    "delete": [
      {
        "operation": "DeleteApplication",
        "requestType": "dataflow.DeleteApplicationRequest",
        "responseType": "dataflow.DeleteApplicationResponse"
      }
    ]
  },
  "lifecycle": {
    "create": {
      "pending": [],
      "target": [
        "ACTIVE",
        "INACTIVE"
      ]
    },
    "update": {
      "pending": [],
      "target": [
        "ACTIVE",
        "INACTIVE"
      ]
    }
  },
  "mutation": {
    "mutable": [
      "application_log_config",
      "archive_uri",
      "arguments",
      "class_name",
      "configuration",
      "defined_tags",
      "description",
      "display_name",
      "driver_shape",
      "driver_shape_config",
      "execute",
      "executor_shape",
      "executor_shape_config",
      "file_uri",
      "freeform_tags",
      "idle_timeout_in_minutes",
      "language",
      "logs_bucket_uri",
      "max_duration_in_minutes",
      "metastore_id",
      "num_executors",
      "parameters",
      "pool_id",
      "private_endpoint_id",
      "spark_version",
      "warehouse_bucket_uri"
    ],
    "forceNew": [
      "compartment_id",
      "type"
    ],
    "conflictsWith": {}
  },
  "hooks": {
    "create": [
      {
        "helper": "tfresource.CreateResource"
      },
      {
        "helper": "tfresource.WaitForWorkRequestWithErrorHandling",
        "entityType": "template",
        "action": "CREATED"
      }
    ],
    "update": [
      {
        "helper": "tfresource.UpdateResource"
      }
    ],
    "delete": [
      {
        "helper": "tfresource.DeleteResource"
      }
    ]
  },
  "deleteConfirmation": {
    "pending": [
      "DELETING"
    ],
    "target": [
      "DELETED"
    ]
  },
  "listLookup": {
    "datasource": "oci_dataflow_applications",
    "collectionField": "applications",
    "responseItemsField": "Items",
    "filterFields": [
      "compartment_id",
      "display_name",
      "display_name_starts_with",
      "owner_principal_id",
      "spark_version"
    ]
  },
  "boundary": {
    "providerFactsOnly": true,
    "repoAuthoredSpecPath": "controllers/dataflow/application/spec.cfg",
    "repoAuthoredLogicGapsPath": "controllers/dataflow/application/logic-gaps.md",
    "excludedSemantics": [
      "bind-versus-create",
      "list-lookup",
      "mutation-policy",
      "status-projection",
      "delete-confirmation",
      "waiter-work-request",
      "secret-output"
    ]
  },
  "notes": [
    "Pinned OCI SDK contract: CreateApplication, GetApplication, ListApplications, UpdateApplication, and DeleteApplication are the available CRUD and lookup operations for dataflow/Application.",
    "Pinned OCI SDK lifecycle contract: Application responses expose ACTIVE, INACTIVE, DELETING, and DELETED; there is no separate PROVISIONING or UPDATING lifecycle enum in the vendored SDK surface.",
    "Pinned SDK request surface: UpdateApplicationDetails exposes archive_uri, application_log_config, arguments, class_name, configuration, defined_tags, description, display_name, driver/executor shape fields, execute, file_uri, language, logs_bucket_uri, metastore_id, num_executors, parameters, pool/private endpoint IDs, spark_version, warehouse_bucket_uri, and timeout fields as update payload inputs.",
    "The package-local runtime intentionally does not use list-based bind-or-reuse semantics for create. Tracked status.osokStatus.ocid is preflighted with GetApplication, and only confirmed NotFound or DELETED clears the tracked identity before a fresh CreateApplication call.",
    "Delete confirmation is repo-authored and absence-based: DeleteApplication is followed by GetApplication until OCI stops finding the resource; observed ACTIVE, INACTIVE, and DELETING remain finalizer-holding intermediate states, while DELETED or NotFound confirm removal."
  ]
}
