{
  "schemaVersion": 1,
  "surface": "provider-facts",
  "service": "core",
  "slug": "vcn",
  "kind": "Vcn",
  "sourceRef": "terraform-provider-oci",
  "providerResource": "oci_core_vcn",
  "operations": {
    "create": [
      {
        "operation": "CreateVcn",
        "requestType": "core.CreateVcnRequest",
        "responseType": "core.CreateVcnResponse"
      }
    ],
    "get": [
      {
        "operation": "GetVcn",
        "requestType": "core.GetVcnRequest",
        "responseType": "core.GetVcnResponse"
      }
    ],
    "list": [
      {
        "operation": "ListVcns",
        "requestType": "core.ListVcnsRequest",
        "responseType": "core.ListVcnsResponse"
      }
    ],
    "update": [
      {
        "operation": "UpdateVcn",
        "requestType": "core.UpdateVcnRequest",
        "responseType": "core.UpdateVcnResponse"
      }
    ],
    "delete": [
      {
        "operation": "DeleteVcn",
        "requestType": "core.DeleteVcnRequest",
        "responseType": "core.DeleteVcnResponse"
      }
    ]
  },
  "lifecycle": {
    "create": {
      "pending": [
        "PROVISIONING"
      ],
      "target": [
        "AVAILABLE"
      ]
    },
    "update": {
      "pending": [
        "UPDATING"
      ],
      "target": [
        "AVAILABLE"
      ]
    }
  },
  "mutation": {
    "mutable": [
      "defined_tags",
      "display_name",
      "freeform_tags",
      "security_attributes",
      "is_zpr_only"
    ],
    "forceNew": [
      "byoipv6_cidr_details",
      "cidr_block",
      "cidr_blocks",
      "compartment_id",
      "dns_label",
      "ipv6_private_cidr_blocks",
      "is_ipv6_enabled",
      "is_oracle_gua_allocation_enabled"
    ],
    "conflictsWith": {
      "cidr_block": [
        "cidr_blocks"
      ],
      "cidr_blocks": [
        "cidr_block"
      ]
    }
  },
  "hooks": {
    "create": [
      {
        "helper": "tfresource.CreateResource"
      },
      {
        "helper": "tfresource.WaitForWorkRequestWithErrorHandling",
        "entityType": "template",
        "action": "CREATED"
      }
    ],
    "update": [
      {
        "helper": "tfresource.UpdateResource"
      }
    ],
    "delete": [
      {
        "helper": "tfresource.DeleteResource"
      }
    ]
  },
  "deleteConfirmation": {
    "pending": [
      "TERMINATING",
      "TERMINATED"
    ],
    "target": [
      "NOT_FOUND"
    ]
  },
  "listLookup": {
    "datasource": "oci_core_vcns",
    "collectionField": "vcn",
    "responseItemsField": "Items",
    "filterFields": [
      "compartment_id",
      "display_name",
      "id",
      "state"
    ]
  },
  "boundary": {
    "providerFactsOnly": true,
    "repoAuthoredSpecPath": "controllers/core/vcn/spec.cfg",
    "repoAuthoredLogicGapsPath": "controllers/core/vcn/logic-gaps.md",
    "excludedSemantics": [
      "bind-versus-create",
      "secret-output"
    ]
  },
  "notes": [
    "Pinned OCI SDK contract: UpdateVcnDetails exposes defined_tags, display_name, freeform_tags, security_attributes, and is_zpr_only as in-place updates.",
    "Repo-authored mutation policy keeps explicit empty display_name and explicit empty tag-map updates intact so retained OCI values can be cleared through UpdateVcnDetails instead of being pruned as no-op drift.",
    "Repo-authored delete confirmation requires GetVcn to return not found; observed TERMINATED remains an accepted intermediate state."
  ]
}
