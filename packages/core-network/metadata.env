PACKAGE_NAME=oci-service-operator-core-network
PACKAGE_NAMESPACE=oci-service-operator-core-network-system
PACKAGE_NAME_PREFIX=oci-service-operator-core-network-
CRD_PATHS=./api/core/...
CRD_KIND_FILTER=Drg,InternetGateway,NatGateway,NetworkSecurityGroup,RouteTable,SecurityList,ServiceGateway,Subnet,Vcn
RBAC_PATHS=./controllers/core/...
DEFAULT_CONTROLLER_IMAGE=iad.ocir.io/oracle/oci-service-operator-core-network:latest
